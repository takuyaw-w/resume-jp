{
  "workspace": [
    "./packages/cli",
    "./packages/core",
    "./packages/types",
    "./packages/theme-api",
    "./packages/theme-jp-common",
    "./packages/theme-jp-basic",
    "./packages/theme-jp-modern",
    "./packages/ui-app"
  ],
  "imports": {
    "@cliffy/command": "jsr:@cliffy/command@^1.0.0",
    "@hono/hono": "jsr:@hono/hono@^4.12.14",
    "@puppeteer/browsers": "npm:@puppeteer/browsers@^2.13.0",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/jsonc": "jsr:@std/jsonc@^1.0.2",
    "@std/path": "jsr:@std/path@^1.1.4",
    "@std/yaml": "jsr:@std/yaml@^1.0.12",
    "preact": "npm:preact@^10.29.1",
    "preact-render-to-string": "npm:preact-render-to-string@^6.6.7",
    "puppeteer-core": "npm:puppeteer-core@^24.42.0",
    "zod": "npm:zod@^4.3.6"
  },
  "compilerOptions": {
    "jsx": "precompile",
    "jsxImportSource": "preact"
  },
  "tasks": {
    "resume": "deno task --filter @resume/cli dev",
    "check": "deno fmt --check && deno lint && deno test",
    "fmt": "deno fmt",
    "lint": "deno lint",
    "test": "deno test",
    "compile": "deno run -A ./scripts/compile.ts",
    "ui:dev": "deno task --cwd packages/ui-app dev",
    "ui:build": "deno task --cwd packages/ui-app build",
    "ui:preview": "deno task --cwd packages/ui-app preview"
  },
  "nodeModulesDir": "auto",
  "lint": {
    "rules": {
      "exclude": ["no-slow-types"]
    }
  },
  "allowScripts": ["npm:puppeteer@24.41.0"]
}
